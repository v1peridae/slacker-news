---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPosts, getSiteConfig, truncateWords } from "../lib/content";

const site = await getSiteConfig();
const opinionPosts = (await getPosts()).filter((post) => post.category === "opinion");
---

<BaseLayout title="Opinion Archive" siteTitle={site.title} siteDescription={site.description}>
  <div class="archive-page">
    <div class="section-label">OPINION</div>
    <hr class="section-rule" />
    <div class="archive-list">
      {opinionPosts.map((post) => (
        <a href={post.url} class="front-block story-block">
          <h3 class="story-block-title">{post.title}</h3>
          <p class="story-block-excerpt">{truncateWords(post.excerpt, 18)}</p>
          <span class="reading-time">{post.readingTime} min read</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
